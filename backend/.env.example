# --- LLM (OpenAI-compatible endpoint) ---
# Works with OpenAI, Azure OpenAI, vLLM, LM Studio, OpenRouter, Ollama (OpenAI-compat), etc.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# --- Storage ---
# Paths are relative to the backend container's working dir; defaults work with the
# docker-compose volume mount of ./data -> /app/data.
DATA_DIR=./data
SQLITE_PATH=./data/confbot.db
CHECKPOINT_PATH=./data/checkpoints.db
MCP_CONFIG_PATH=./data/mcp.json

# --- Server ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
